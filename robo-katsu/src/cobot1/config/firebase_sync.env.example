# cobot1 Firebase Realtime Database sync 설정 예시.
#
# 실제 env 파일은 ~/.config/cobot1/firebase/firebase_sync.env 로 복사해서 사용하세요.
#   mkdir -p ~/.config/cobot1/firebase
#   cp $(ros2 pkg prefix cobot1)/share/cobot1/config/firebase_sync.env.example \
#      ~/.config/cobot1/firebase/firebase_sync.env
#   # 서비스 계정 JSON 도 같은 폴더에 배치:
#   cp <service-account>.json ~/.config/cobot1/firebase/
#   chmod 600 ~/.config/cobot1/firebase/*
#
# 또는 FIREBASE_SYNC_ENV_FILE 환경변수로 임의 경로 지정 가능:
#   FIREBASE_SYNC_ENV_FILE=/path/to/firebase_sync.env ros2 run cobot1 ui_bridge

FIREBASE_DATABASE_URL=https://rokey-b-1-default-rtdb.asia-southeast1.firebasedatabase.app/

# 서비스 계정 JSON. 상대경로면 이 env 파일과 같은 폴더 기준으로 해석됨.
# 비워두면 env 파일과 같은 폴더의 *-firebase-adminsdk-*.json 이 자동 탐지됨.
FIREBASE_SERVICE_ACCOUNT_FILE=./rokey-b-1-firebase-adminsdk-fbsvc-605b9577d3.json

# 최신 스냅샷 경로 (매 status publish 마다 set 오버라이트)
FIREBASE_STATUS_PATH=robots/m0609/status

# 이벤트 로그 append 경로 (의미 있는 상태 전이 시 push).
# 필요 없으면 주석 처리. (스냅샷만 쓰고 싶은 경우)
FIREBASE_EVENTS_PATH=robots/m0609/events

# HTTP 타임아웃 및 heartbeat (동일 시그니처 재전송 주기) — 선택 사항.
FIREBASE_SYNC_TIMEOUT_SEC=3
FIREBASE_SYNC_HEARTBEAT_SEC=5

# REST fallback 시 DB rule 이 auth 를 요구하는 경우만 사용.
# admin SDK 인증이 동작 중이면 무시됨.
# FIREBASE_DATABASE_AUTH=
